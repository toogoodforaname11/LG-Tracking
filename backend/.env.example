# PostgreSQL (auto-configured by deploy.sh on Hostinger VPS)
DATABASE_URL=postgresql+asyncpg://lg_user:CHANGE_ME@localhost:5432/lg_tracking
DATABASE_URL_SYNC=postgresql://lg_user:CHANGE_ME@localhost:5432/lg_tracking

# Gemini (optional — enables AI matching and summarization)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Perplexity (optional — enables claim verification)
PERPLEXITY_API_KEY=

# SMTP (Hostinger email — required for email delivery)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=BC Local Government Council Tracker <noreply@lg-tracker.ca>

# App base URL — used to build unsubscribe links in emails (no trailing slash)
# e.g. https://your-domain.com
APP_BASE_URL=

# CORS — comma-separated list of allowed origins
# e.g. http://localhost:3000,https://your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Cron secret — protects cron and admin endpoints (POST /seed, /cron/*)
# Set to any non-empty random string. Callers must send: X-Cron-Secret: <value>
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=

# Debug mode — set to false in production (true enables SQL query logging)
DEBUG=false
