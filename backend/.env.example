# Neon Postgres (required)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/hearing_watch?sslmode=require
DATABASE_URL_SYNC=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/hearing_watch?sslmode=require

# Gemini (optional — enables AI matching and summarization)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Perplexity (optional — enables claim verification)
PERPLEXITY_API_KEY=

# Resend (required for email delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=BC Local Government Council Tracker <noreply@bchearingwatch.ca>

# App base URL — used to build unsubscribe links in emails (no trailing slash)
# e.g. https://your-domain.com
APP_BASE_URL=

# CORS — comma-separated list of allowed origins
# e.g. http://localhost:3000,https://your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Cron secret — protects cron and admin endpoints (POST /seed, /cron/*)
# Set to any non-empty random string. Callers must send: X-Cron-Secret: <value>
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=

# Debug mode — set to false in production (true enables SQL query logging)
DEBUG=false
